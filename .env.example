# ── Application ──
APP_NAME=ecommerce-smartops-agent
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── LLM Gateway ──
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=60

# ── Embedding ──
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──
CHROMA_MODE=embedded
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./data/chroma

# ── Agent ──
MAX_AGENT_STEPS=10
CONVERSATION_WINDOW_SIZE=5
CONFIDENCE_THRESHOLD=0.55
RATE_LIMIT_PER_MINUTE=10

# ── Security ──
API_KEY_HEADER=X-API-Key
ADMIN_API_KEYS=[]
TENANT_HEADER=X-Tenant-ID
CORS_ORIGINS=["*"]

# ── Document Processing ──
MAX_UPLOAD_SIZE_MB=50
ALLOWED_DOCUMENT_TYPES=["pdf","docx","txt","md","html"]
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── API Keys for External Tools (Mock by default) ──
# Google Shopping
GOOGLE_SHOPPING_API_KEY=
# Meta Ads (Facebook Marketing API) — https://developers.facebook.com/
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
# Shopify — https://admin.shopify.com/store/你的店铺/settings/apps
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_KEY=
SHOPIFY_API_PASSWORD=
# Amazon Seller — https://sellercentral.amazon.com/
AMAZON_SELLER_ID=
AMAZON_ACCESS_TOKEN=
# Google Ads — https://developers.google.com/google-ads/api/
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# ERP
ERP_API_URL=
ERP_API_KEY=
